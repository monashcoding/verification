# Postgres — user/password/db all match the project name per spec §3.
DATABASE_URL=postgres://mac_membership_verify:mac_membership_verify@localhost:5432/mac_membership_verify

# mac-auth integration (§5). This service only *verifies* tokens. JWKS is derived
# as ${AUTH_URL}/api/auth/jwks; issuer is AUTH_URL; audience defaults to mac-suite.
AUTH_URL=https://auth.monashcoding.com
JWT_AUDIENCE=mac-suite

# Comma-separated role claims that grant admin surfaces (§11). exec/committee.
MAC_ADMIN_ROLES=exec,committee

# Code generation (§4) — secret so codes aren't guessable from public data.
CODE_SECRET=change-me-to-a-long-random-string
CODE_PREFIX=MAC

# Code provisioning ping (§9). Unset → the cron logs instead of posting.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Humanitix read-only API (list live events in the admin). Generate a key in the
# Humanitix account under Settings → API Keys. Unset → the admin falls back to
# manual event entry.
HUMANITIX_API_KEY=

# Frontend (Vite, VITE_ prefix is exposed to the browser).
VITE_AUTH_URL=https://auth.monashcoding.com

PORT=3000
