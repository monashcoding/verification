# Postgres — user/password/db all match the project name per spec §3.
DATABASE_URL=postgres://mac_membership_verify:mac_membership_verify@localhost:5432/mac_membership_verify

# mac-auth integration (§5). This service only *verifies* tokens.
MAC_AUTH_JWKS_URL=https://auth.monashcoding.com/.well-known/jwks.json
MAC_AUTH_ISSUER=https://auth.monashcoding.com
# MAC_AUTH_AUDIENCE=            # optional, set if mac-auth issues an aud claim

# Comma-separated role claims that grant admin surfaces (§11).
MAC_ADMIN_ROLES=admin,exec,committee

# Code generation (§4) — secret so codes aren't guessable from public data.
CODE_SECRET=change-me-to-a-long-random-string
CODE_PREFIX=MAC

# Code provisioning ping (§9). Unset → the cron logs instead of posting.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Frontend (Vite, VITE_ prefix is exposed to the browser).
VITE_MAC_AUTH_LOGIN_URL=https://auth.monashcoding.com/login

PORT=3000
